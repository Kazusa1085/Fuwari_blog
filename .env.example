# 复制这个文件为 .env，按需修改
#
# ============================================
# 内容分离配置
# ============================================
# 文章 (content/posts)、友链 (content/friends)、项目 (content/projects)
# 从独立仓库 Kazusa1085/Blog_Archive 同步到本地的 content/ 目录。

# 是否启用内容分离，从独立仓库同步 content/ 目录 (true/false)
ENABLE_CONTENT_SYNC=true

# 内容仓库的 Git 地址
CONTENT_REPO_URL=https://github.com/Kazusa1085/Blog_Archive.git

# 内容目录路径（相对于项目根目录），一般不需要改动
# CONTENT_DIR=content
