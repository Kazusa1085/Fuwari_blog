---
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { Icon } from "astro-icon/components";
import { url } from "@utils/url-utils";
---

<MainGridLayout title="页面走丢了" description="你访问的页面不存在，可能已经被移动或删除。">
    <div class="flex flex-col items-center justify-center text-center py-16 md:py-24 px-4">
        <Icon name="material-symbols:search-off-rounded"
              class="text-[4.5rem] md:text-[5.5rem] text-[var(--primary)] opacity-80 mb-3 onload-animation" />

        <h1 class="text-6xl md:text-7xl font-bold text-black/90 dark:text-white/90 onload-animation"
            style="animation-delay: 50ms">
            404
        </h1>

        <p class="text-xl md:text-2xl font-bold mt-3 text-black/80 dark:text-white/80 onload-animation"
           style="animation-delay: 100ms">
            这里什么都没有喵~
        </p>

        <p class="mt-3 max-w-md text-black/50 dark:text-white/50 onload-animation"
           style="animation-delay: 150ms">
            你访问的页面不存在，可能已经被移动、删除，或者链接本身就打错了。
        </p>

        <div class="flex flex-wrap items-center justify-center gap-3 mt-8 onload-animation"
             style="animation-delay: 200ms">
            <a href={url("/")}
               class="btn-card rounded-xl h-11 px-6 flex items-center gap-2 font-bold text-[var(--primary)]">
                <Icon name="material-symbols:home-rounded" class="text-lg" />
                返回首页
            </a>
            <a href={url("/archive/")}
               class="btn-card rounded-xl h-11 px-6 flex items-center gap-2 font-bold text-black/70 dark:text-white/70">
                <Icon name="material-symbols:archive-outline-rounded" class="text-lg" />
                查看文章归档
            </a>
        </div>
    </div>
</MainGridLayout>
